

:root
    --theme-bg-0 #0b1214
    --theme-bg-1 #111b1f
    --theme-bg-2 #1a2a30
    --theme-panel rgba(15, 24, 27, 0.88)
    --theme-panel-strong rgba(11, 18, 20, 0.94)
    --theme-panel-soft rgba(28, 42, 47, 0.78)
    --theme-paper #efe3cf
    --theme-paper-soft rgba(239, 227, 207, 0.76)
    --theme-text #f7efde
    --theme-text-muted rgba(247, 239, 222, 0.72)
    --theme-line rgba(239, 227, 207, 0.26)
    --theme-line-strong rgba(239, 227, 207, 0.52)
    --theme-accent #cf9361
    --theme-accent-strong #f0b87a
    --theme-accent-secondary #4f8d85
    --theme-success #b8cf83
    --theme-danger #df7f5d
    --theme-shadow rgba(0, 0, 0, 0.38)

*
    box-sizing border-box
    margin 0
    padding 0
    -webkit-tap-highlight-color transparent

button
input
    background none
    color inherit
    border none
    padding 0
    font inherit
    outline inherit

button
    cursor pointer

html
body
.game
.modals
.menu
    position fixed
    top 0
    left 0
    width 100%
    height 100%
    font-family "Nunito", sans-serif
    font-optical-sizing auto
    font-weight 400
    font-style normal
    -webkit-font-smoothing antialiased
    -moz-osx-font-smoothing grayscale
    overflow hidden
    color var(--theme-text)

.experience
    touch-action none

    .input-filter-wandering &,
    .input-filter-intro &
        cursor grab

        &:active
            cursor grabbing

html
    background radial-gradient(circle at top left, rgba(88, 129, 121, 0.32), transparent 32%), radial-gradient(circle at bottom right, rgba(207, 147, 97, 0.18), transparent 28%), linear-gradient(160deg, var(--theme-bg-2), var(--theme-bg-0) 60%, #060a0b)
    font-size 20px
    touch-action manipulation // Prevents double tap zoom

    @media only screen and (max-width 520px)
        font-size 18px

    @media only screen and (max-width 440px)
        font-size 16px;

ul
ol
    padding-left 25px

.title
    margin-bottom 0.35em
    font-size 2.35rem
    font-family "Amatic SC", sans-serif
    font-weight 600
    font-style normal
    line-height 0.92
    letter-spacing 0.03em
    text-transform uppercase
    color var(--theme-paper)

.text
    margin-bottom 0.75em
    font-size 1rem
    color var(--theme-text-muted)
    line-height 1.65

    a
        color var(--theme-accent-strong)
        text-decoration underline

.text-small
    font-size 0.8rem

.text-danger
    color var(--theme-danger)
    
    .icon
        vertical-align sub

.text-faded
    opacity 0.8

.text-align-right
    text-align right

.text-align-center
    text-align center

.horizontal-group
    display flex
    align-items center
    justify-content center
    gap 10px

    @media only screen and (max-width 520px)
        flex-direction column

    > *
        // margin-right 10px

        // &:last-child
        //     margin-right 0
        
a.button
        display inline-block

.button
    vertical-align top
    display inline-flex
    align-items center
    justify-content center
    gap 10px
    padding 0 20px
    height 58px
    line-height 58px
    border-radius 999px
    white-space nowrap
    background linear-gradient(135deg, rgba(34, 52, 58, 0.92), rgba(12, 19, 22, 0.96))
    box-shadow inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 12px 28px rgba(0, 0, 0, 0.2)
    text-decoration none
    border 1px solid var(--theme-line)
    color var(--theme-paper-soft)
    cursor default
    letter-spacing 0.08em
    text-transform uppercase
    font-size 0.72rem
    font-weight 700

    @media only screen and (max-width 520px)
        padding 0 13px
        height 50px
        line-height 50px

    @media only screen and (max-width 440px)
        padding 0 10px
        height 45px
        line-height 45px

    &:not(.is-disabled)
        cursor pointer

    &.is-disabled
        border-style dashed

        &.has-tooltip
            cursor help

    &.is-success
        color var(--theme-success)

    &.is-danger
        color var(--theme-danger)

    html:not(.is-mode-touch) &:not(.is-disabled):hover
        border 1px solid var(--theme-line-strong)
        color var(--theme-paper)
        transform translateY(-1px)
        box-shadow inset 0 1px 0 rgba(255, 255, 255, 0.06), 0 18px 36px rgba(0, 0, 0, 0.24)

    .icon
        position relative
        vertical-align middle

        &.icon-audio
            top -2px

        &.icon-restart
            top -2px

        &.icon-flag
            top -1px

        &.icon-controller
            top -1px

.input-group
    display flex
    height 58px

    &.is-message
        width 100%
        margin-top 1.5em

        .input-text
            width calc(100% - 62px * 2)
            padding 0 15px 0 5px

    &.is-name-tag
        .input-text
            width 100px
            font-size 25px
            letter-spacing 8px
            text-transform uppercase
            font-weight 700
            // padding 0 15px 0 5px

            &::placeholder
                letter-spacing 14px
                padding-left 4px

    > *
        border-top 1px solid var(--theme-line)
        border-bottom 1px solid var(--theme-line)

    >:first-child
        border-radius 18px 0 0 18px
        border-left 1px solid var(--theme-line)

    &.is-valide
        button
            cursor pointer
            border-color var(--theme-accent-strong)
            color var(--theme-accent-strong)

            &.has-icon
                svg
                    *
                        stroke var(--theme-accent-strong)

    .input-text
        padding 0 15px 0 5px

    .submit
        border-radius 0 18px 18px 0
        border 1px solid var(--theme-line)
        cursor default
        color var(--theme-text-muted)

        &.has-text
            padding 0 20px

        &.has-icon
            width 62px
            padding 0 8px 0 4px

            svg
                *
                    stroke var(--theme-text-muted)

    .input-flag
        position relative
        width 62px
        font-size 16px

        .flag-button
            position absolute
            top 0
            left 0
            width 100%
            height 100%
            display flex
            justify-content center
            align-items center
            cursor pointer

            &.has-flag
                .flag
                    display block

                svg
                    display none

            .flag
                display none
                width 27px
                height 18px

            html:not(.is-mode-touch) &:hover
                svg
                    *
                        fill #cccccc

            svg
                display block

                *
                    fill #555555

        .flag-select
            display none
            position absolute
            bottom 0
            left 8px
            width 350px
            height 240px
            background linear-gradient(160deg, rgba(18, 29, 31, 0.98), rgba(10, 16, 18, 0.98))
            border-radius 18px 18px 0 0
            border 1px solid var(--theme-line)
            border-bottom none
            box-shadow 0 24px 50px rgba(0, 0, 0, 0.3)
            overflow hidden
            white-space nowrap
            z-index 1

            &.is-visible
                display block

            .close-mini
                display flex
                align-items center
                justify-content center
                position absolute
                height 40px
                width 34px
                top 0
                right 0
                opacity 0.65
                cursor pointer

                html:not(.is-mode-touch) &:hover
                    opacity 1

                img
                    position relative
                    top 4px
                    left -3px
            

            .remove
                display flex
                align-items center
                justify-content center
                position absolute
                height 40px
                width 34px
                top 0
                right 30px
                opacity 0.65
                cursor pointer

                html:not(.is-mode-touch) &:hover
                    opacity 1

                img
                    position relative
                    top 3px
            
            .search
                height 40px
                width 100%
                padding 4px 35px 0 10px

            .no-result
                display none
                justify-content center
                align-items center
                position absolute
                top 30px
                bottom 0
                left 0
                right 0
                opacity 0.65
                pointer-events none

                &.is-visible
                    display flex
            
            .choices
                position absolute
                top 40px
                bottom 0
                left 0
                right 0
            
                .scroller
                    position absolute
                    top 0
                    left 0
                    width calc(100% + 20px)
                    height 100%
                    overflow-y scroll
                    overflow-x hidden

                .choice
                    display flex
                    padding 4px 8px
                    cursor pointer

                    html:not(.is-mode-touch) &:hover
                        .label
                            opacity 1

                    .label
                        opacity 0.65

                    .flag
                        margin-right 8px
                        width 27px
                        height 18px

html:not(.is-server-offline) .offline-element
    display none !important

html:not(.is-server-online) .online-element
    display none !important

