.menu .whispers-preview
    display flex
    align-items center
    justify-content center
    padding-bottom 80px

    .message
        position relative
        background rgba(11, 18, 20, 0.92)
        padding 10px 16px 12px 16px
        border 1px solid var(--theme-line)
        border-radius 22px
        box-shadow 0 18px 38px rgba(0, 0, 0, 0.28)

        .text
            font-size 2.5rem
            white-space nowrap
            color #ffffff
            border none
            outline none

        .flag
            position absolute
            bottom calc(100% - 12px)
            right -16px
            width 54px
            height 36px
            background red
            background-size cover
            transform rotate(15deg)
            display none

            &.is-visible
                display block
